<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{{ "header.subtitle" | trans }}{% block title %}{% endblock %}</title>

    <link rel="icon" href="favicon.svg" type="image/x-icon">

    {% block stylesheets %}
        {{ encore_entry_link_tags('css/app') }}
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('js/app') }}
    {% endblock %}
</head>
<body>
<div id="page-wrapper">
    {% block body %}{% endblock %}
</div>
</body>
</html>
